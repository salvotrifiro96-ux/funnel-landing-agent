# Backend keys owned by the SaaS operator (you).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Higgsfield (Nano Banana Pro) — image generation via cookie auth.
# Refresh from DevTools → Application → Cookies → higgsfield.ai
HIGGSFIELD_CLERK_CLIENT=eyJhbGc...           # cookie __client — required, ~30d TTL
HIGGSFIELD_SESSION_ID=                        # optional — auto-discovered from __client
HIGGSFIELD_CF_CLEARANCE=                      # cookie cf_clearance — required when fnf.* is behind Cloudflare bot challenge
HIGGSFIELD_USER_AGENT=                        # optional — paste the same browser UA that generated cf_clearance

# GitHub publishing — fine-grained or classic PAT with `repo` scope.
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_USERNAME=salvotrifiro96-ux
GITHUB_PAGES_REPO=funnel-landing-pages
LANDING_BASE_URL=https://landing.leonemasterschool.it

# App password to gate the Streamlit UI.
APP_PASSWORD=changeme

# Usage logging via Google Apps Script webhook (optional)
USAGE_LOG_WEBHOOK_URL=
USAGE_LOG_WEBHOOK_SECRET=
